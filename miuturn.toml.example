[log]
log_level="info"
#log_file="/var/log/miuturn.log"

[server]
realm = "miuda.ai"
external_ip = "0.0.0.0"
relay_bind_ip = "0.0.0.0"
start_port = 49152
end_port = 65535
# Stats dump interval in seconds, set to 0 to disable (default: 30)
stats_dump_interval_secs = 30
# Skip stats dump if no data change since last dump (default: true)
stats_dump_skip_if_no_change = true
# Server name for SOFTWARE attribute in TURN responses (default: miuturn/0.1.2)
server_name = "miuturn/0.1.2"

[[server.listening]]
protocol = "udp"
address = "0.0.0.0:3478"

#[[server.listening]]
#protocol = "tcp"
#address = "0.0.0.0:3478"

#[http]
#address = "0.0.0.0:8080"
# Admin console ACL: list of allowed IPs/CIDRs (default: ["127.0.0.1"])
#admin_acl = ["127.0.0.1", "192.168.1.0/24"]
# Trust X-Forwarded-For / X-Real-IP headers when checking admin ACL (default: false)
#trust_proxy = false

[[auth.users]]
username = "miuturn.admin"
password = "miuturn.pwd.changeme"
user_type = "fixed"
max_allocations = 10

[[auth.acl_rules]]
ip_range = "0.0.0.0/0"
action = "allow"
priority = 0